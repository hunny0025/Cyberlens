# CyberLens v3.0 — Criminal Intelligence Platform
# Copy to .env and fill in your values
# ============================================================

# ── Core Database ────────────────────────────────────────────
DATABASE_URL=sqlite:///data/cyberlens.db

# ── Server ───────────────────────────────────────────────────
DEBUG=True
PORT=8000
HOST=0.0.0.0

# ── Authentication ───────────────────────────────────────────
# IMPORTANT: Change this before production deployment!
SECRET_KEY=change-this-to-a-random-secret-key-minimum-32-characters
ACCESS_TOKEN_EXPIRE_MINUTES=480
AUTH_DISABLED=true
# Set AUTH_DISABLED=false for production to enforce JWT login

# ── PII Protection ──────────────────────────────────────────
PII_MASKING=true
# Masks phone/UPI/Aadhaar in log files

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_DIR=logs/
AUDIT_LOG_DIR=logs/audit/

# ── ML Models ────────────────────────────────────────────────
MODEL_DIR=models/

# ── Neo4j (Criminal Network Graph — Prompt 7) ────────────────
# Install: docker run --publish=7474:7474 --publish=7687:7687 neo4j:5
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=cyberlens2025

# ── OCR Engines (Prompt 8) ───────────────────────────────────
# Mistral Vision API (best OCR)
# Get key: https://console.mistral.ai
MISTRAL_API_KEY=your_mistral_key_here

# Google Cloud Vision (optional fallback)
GOOGLE_VISION_API_KEY=your_gcp_key_here

# ── Qdrant Vector DB (Prompt 10) ─────────────────────────────
# Local mode (no server needed)
QDRANT_PATH=data/qdrant
QDRANT_URL=http://localhost:6333

# ── Telegram Monitor (Prompt 11) ─────────────────────────────
# Get from: https://my.telegram.org/apps (free)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION_STRING=

# ── Gemini AI (Prompt 12) ────────────────────────────────────
GEMINI_API_KEY=your_gemini_key_here

# ── SMS Alerts (Fix 9) ──────────────────────────────────────
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ── Email Alerts (Fix 9) ────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_FROM_EMAIL=cyberlens@gpcssi.gov.in

# ── NPCI UPI Freeze (Fix 6) ─────────────────────────────────
NPCI_API_URL=
NPCI_API_KEY=

# ── Google Safe Browsing (Fix 10 — OSINT) ────────────────────
# Get from: https://console.cloud.google.com/apis/library/safebrowsing.googleapis.com
GOOGLE_SAFE_BROWSING_KEY=

# ── I4C Portal ───────────────────────────────────────────────
I4C_API_KEY=your_i4c_key_here
I4C_PORTAL_URL=https://cybercrime.gov.in/api/v1

# ── Evidence Storage ─────────────────────────────────────────
EVIDENCE_DIR=data/evidence/
FIR_OUTPUT_DIR=data/reports/fir/
